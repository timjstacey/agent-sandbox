# Container-local Claude state — deny all, allow only committed config files.
# Add a !/.claude/<file> negation here to deliberately track a new file.
/.env
/.claude.json
/.claude/*
!/.claude/settings.json
!/.claude/mcp-config.json
!/.claude/combined-statusline.sh

# Container-local gh auth — bind-mounted dir holding the session token
# (plaintext hosts.yml, machine/session state). Created by setup.
/.config/gh/
