{
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/docker-compose*.yml)",
      "Read(**/config/database.yml)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=$(find \"$HOME/.claude/plugins/cache/caveman\" -name caveman-activate.js 2>/dev/null | head -1); [ -n \"$f\" ] && node \"$f\" || true'",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=$(find \"$HOME/.claude/plugins/cache/caveman\" -name caveman-mode-tracker.js 2>/dev/null | head -1); [ -n \"$f\" ] && node \"$f\" || true'",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/combined-statusline.sh\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "worktrunk@worktrunk": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "skipAutoPermissionPrompt": true
}
