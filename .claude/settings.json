{
  "model": "Opus",
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/docker-compose*.yml)",
      "Read(**/config/database.yml)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty'); echo \"$cmd\" | grep -q 'gh pr create' && printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"CODE REVIEW GATE: Run /caveman-review (Skill tool, skill=\\\"caveman:caveman-review\\\") to review the diff before opening this PR. Do not call gh pr create until the review is done.\"}}' || true"
          },
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty'); echo \"$cmd\" | grep -Eq 'git (checkout -b|switch -c|branch [^-])' || exit 0; git worktree list 2>/dev/null | head -1 | grep -q '(bare)' || exit 0; printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"BARE/WORKTRUNK REPO: create branches with \\\"wt switch -c <branch>\\\", not raw git branch creation. See CLAUDE.md workflow conventions.\"}}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=$(find \"$HOME/.claude/plugins/cache/caveman\" -name caveman-activate.js 2>/dev/null | head -1); [ -n \"$f\" ] && node \"$f\" || true'",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=$(find \"$HOME/.claude/plugins/cache/caveman\" -name caveman-mode-tracker.js 2>/dev/null | head -1); [ -n \"$f\" ] && node \"$f\" || true'",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/combined-statusline.sh\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "worktrunk@worktrunk": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "skipAutoPermissionPrompt": true
}
