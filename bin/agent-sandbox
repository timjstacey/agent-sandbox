#!/usr/bin/env bash
set -euo pipefail

# --- Preflight checks ---

# 1. Verify the 'agent' user exists on the host
if ! id agent >/dev/null 2>&1; then
  echo "Error: 'agent' user not found on host. See docs/host-setup.md" >&2
  exit 1
fi

# 2. Verify Claude Code credentials are present and readable
if ! test -r "${HOME}/.claude/.credentials.json"; then
  echo "Error: ~/.claude/.credentials.json not found or not readable. Claude Code auth required." >&2
  exit 1
fi

# 3. Verify SSH_AUTH_SOCK is set and the socket exists
if ! test -S "${SSH_AUTH_SOCK:-}"; then
  echo "Error: SSH_AUTH_SOCK not set or socket missing. Start ssh-agent and add your key." >&2
  exit 1
fi

# 4. Verify gh and tea config directories exist on host.
# Compose would otherwise create them as root-owned mounts, causing permission errors.
for cfg in "${HOME}/.config/gh" "${HOME}/.config/tea"; do
  if ! test -d "${cfg}"; then
    echo "Error: ${cfg} not found. Run 'gh auth login' / 'tea login' first. See docs/host-setup.md" >&2
    exit 1
  fi
done

# 5. Warn (don't exit) if ACLs for 'agent' are missing on ~/Repositories
if ! getfacl "${HOME}/Repositories" 2>/dev/null | grep -q "^user:agent:"; then
  echo "Warning: ACLs for 'agent' not found on ~/Repositories. See docs/host-setup.md" >&2
fi

# --- Locate compose.yml relative to this script ---
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
COMPOSE_FILE="${SCRIPT_DIR}/../compose.yml"

# --- Run ---
exec docker compose -f "${COMPOSE_FILE}" run --rm agent "$@"
