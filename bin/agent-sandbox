#!/usr/bin/env bash
set -euo pipefail

# --- Locate compose.yml relative to this script ---
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
COMPOSE_FILE="${SCRIPT_DIR}/../compose.yml"

# --- agent user must exist for all subcommands ---
if ! id agent >/dev/null 2>&1; then
  echo "Error: 'agent' user not found on host. See docs/host-setup.md" >&2
  exit 1
fi

# --- Dispatch ---
case "${1:-}" in

  setup)
    echo "Granting agent user ACL access to required host paths..."

    sudo setfacl -m u:agent:x "${HOME}"

    if [[ -d "${HOME}/.claude" ]]; then
      sudo setfacl -R -m u:agent:rwX "${HOME}/.claude"
      sudo setfacl -R -d -m u:agent:rwX "${HOME}/.claude"
    else
      echo "Warning: ~/.claude not found — skipping. Re-run after 'claude' creates it." >&2
    fi

    if [[ -f "${HOME}/.claude.json" ]]; then
      sudo setfacl -m u:agent:rw "${HOME}/.claude.json"
    else
      echo "Warning: ~/.claude.json not found — skipping. Re-run after 'claude' creates it." >&2
    fi

    if [[ -f "${HOME}/.gitconfig" ]]; then
      sudo setfacl -m u:agent:r "${HOME}/.gitconfig"
    else
      echo "Warning: ~/.gitconfig not found — skipping." >&2
    fi

    sudo setfacl -R -m u:agent:rwX "${HOME}/Repositories"
    sudo setfacl -R -d -m u:agent:rwX "${HOME}/Repositories"

    for cfg in "${HOME}/.config/gh" "${HOME}/.config/tea"; do
      if [[ -d "${cfg}" ]]; then
        sudo setfacl -R -m u:agent:rwX "${cfg}"
        sudo setfacl -R -d -m u:agent:rwX "${cfg}"
      else
        echo "Warning: ${cfg} not found — skipping. Re-run after 'gh auth login' / 'tea login'." >&2
      fi
    done

    echo "Done. Run './bin/agent-sandbox verify' to confirm."
    ;;

  verify)
    ok=true

    sudo -u agent test -r "${HOME}/.claude/.credentials.json" \
      && echo "credentials:  OK" \
      || { echo "credentials:  FAIL"; ok=false; }

    sudo -u agent test -w "${HOME}/.claude.json" \
      && echo "session:      OK" \
      || { echo "session:      FAIL"; ok=false; }

    sudo -u agent test -r "${HOME}/.gitconfig" \
      && echo "gitconfig:    OK" \
      || { echo "gitconfig:    FAIL"; ok=false; }

    sudo -u agent touch "${HOME}/Repositories/.agent-write-test" \
      && rm "${HOME}/Repositories/.agent-write-test" \
      && echo "repos write:  OK" \
      || { echo "repos write:  FAIL"; ok=false; }

    sudo -u agent sh -c "touch ${HOME}/.config/gh/.agent-write-test && rm ${HOME}/.config/gh/.agent-write-test" \
      && echo "gh write:     OK" \
      || { echo "gh write:     FAIL"; ok=false; }

    sudo -u agent sh -c "touch ${HOME}/.config/tea/.agent-write-test && rm ${HOME}/.config/tea/.agent-write-test" \
      && echo "tea write:    OK" \
      || { echo "tea write:    FAIL"; ok=false; }

    ${ok} && exit 0 || exit 1
    ;;

  build)
    exec docker compose -f "${COMPOSE_FILE}" build \
      --build-arg AGENT_UID="$(id -u agent)" \
      --build-arg AGENT_GID="$(id -g agent)" \
      agent
    ;;

  *)
    # Preflight checks for container run
    mkdir -p "${HOME}/.claude"

    if ! test -d "${HOME}/.claude"; then
      echo "Error: ~/.claude not found. Run 'claude' on the host first or './bin/agent-sandbox setup'." >&2
      exit 1
    fi

    if ! test -f "${HOME}/.claude.json"; then
      echo "Error: ~/.claude.json not found. Run 'claude' on the host first to create it." >&2
      exit 1
    fi

    if ! test -S "${SSH_AUTH_SOCK:-}"; then
      echo "Error: SSH_AUTH_SOCK not set or socket missing. Start ssh-agent and add your key." >&2
      exit 1
    fi

    for cfg in "${HOME}/.config/gh" "${HOME}/.config/tea"; do
      if ! test -d "${cfg}"; then
        echo "Error: ${cfg} not found. Run 'gh auth login' / 'tea login' first." >&2
        exit 1
      fi
    done

    if ! getfacl "${HOME}/Repositories" 2>/dev/null | grep -q "^user:agent:"; then
      echo "Warning: ACLs for 'agent' not found on ~/Repositories. Run './bin/agent-sandbox setup'." >&2
    fi

    exec docker compose -f "${COMPOSE_FILE}" run --rm agent "$@"
    ;;

esac
