#!/usr/bin/env bash
set -euo pipefail

# --- Locate compose.yml relative to this script ---
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
REPO_DIR="$(readlink -f "${SCRIPT_DIR}/..")"
COMPOSE_FILE="${REPO_DIR}/compose.yml"

export HOST_USER="$(id -un)"
export HOST_UID="$(id -u)"
export HOST_GID="$(id -g)"
export COMPOSE_PROJECT_NAME="agent-sandbox-${HOST_USER}"

# --- Resolve GH_TOKEN from host keyring ---
# gh stores the OAuth token in the system keyring, not in ~/.config/gh/hosts.yml.
# Inject it as GH_TOKEN so the in-container gh can authenticate without keyring access.
resolve_gh_token() {
  if ! command -v gh &>/dev/null; then
    echo "Warning: gh not installed on host — container gh will be unauthenticated." >&2
    return
  fi
  local token
  token="$(gh auth token 2>/dev/null)" || true
  if [[ -n "${token}" ]]; then
    export GH_TOKEN="${token}"
  else
    echo "Warning: gh not authenticated on host — container gh will be unauthenticated. Run 'gh auth login' on host or 'gh auth login' inside the container." >&2
  fi
}

# --- Dispatch ---
case "${1:-}" in

  setup)
    echo "Initialising container-local Claude state..."

    # Prompt for projects directory and write .env (docker compose auto-reads it).
    if [[ -f "${REPO_DIR}/.env" ]]; then
      # shellcheck source=/dev/null
      set -a; source "${REPO_DIR}/.env"; set +a
      echo "Projects directory currently set to: ${PROJECTS_DIR}"
      read -r -p "Projects directory to mount [${PROJECTS_DIR}]: " INPUT_DIR
      PROJECTS_DIR="${INPUT_DIR:-${PROJECTS_DIR}}"
    else
      read -r -p "Projects directory to mount [${HOME}/Repositories]: " INPUT_DIR
      PROJECTS_DIR="${INPUT_DIR:-${HOME}/Repositories}"
    fi
    PROJECTS_DIR="${PROJECTS_DIR%/}"  # strip trailing slash
    PROJECTS_BASENAME="$(basename "${PROJECTS_DIR}")"
    cat > "${REPO_DIR}/.env" <<EOF
PROJECTS_DIR=${PROJECTS_DIR}
PROJECTS_BASENAME=${PROJECTS_BASENAME}
EOF
    echo "Wrote .env: PROJECTS_DIR=${PROJECTS_DIR}"

    # .claude/ is committed (settings.json + mcp-config.json tracked in git).
    # Only .claude.json (login state) needs pre-creation as the right inode type
    # before docker bind-mounts it (missing file gets auto-created as a dir).
    if [[ ! -f "${REPO_DIR}/.claude.json" ]]; then
      touch "${REPO_DIR}/.claude.json"
      chmod 0600 "${REPO_DIR}/.claude.json"
    fi

    if [[ ! -d "${HOME}/.config/gh" ]]; then
      echo "Note: ${HOME}/.config/gh missing — creating empty dir. Run 'gh auth login' on host or inside the container." >&2
      mkdir -p "${HOME}/.config/gh"
    fi

    if [[ ! -f "${HOME}/.gitconfig" ]]; then
      echo "Warning: ~/.gitconfig not found — container will lack git identity until you create one." >&2
    fi

    # Pre-install plugins into the bind-mounted .claude/plugins/cache/ so the
    # caveman SessionStart hook fires on first claude launch rather than the
    # second. Requires the image to be built; skip gracefully if not yet done.
    echo "Pre-installing Claude plugins (caveman, worktrunk)..."
    PLUGIN_CACHE="${REPO_DIR}/.claude/plugins/cache"
    mkdir -p "${PLUGIN_CACHE}"
    plugin_ok=true
    for plugin in "caveman:JuliusBrussee/caveman" "worktrunk:max-sixty/worktrunk"; do
      name="${plugin%%:*}"
      repo="${plugin##*:}"
      dest="${PLUGIN_CACHE}/${name}"
      if [[ -d "${dest}" ]]; then
        echo "  ${name}: already cached (delete ${dest} to refresh)"
      else
        echo "  ${name}: downloading from github.com/${repo}..."
        tmp="$(mktemp -d)"
        if curl -fsSL "https://github.com/${repo}/archive/refs/heads/main.tar.gz" \
             | tar -xz --strip-components=1 -C "${tmp}" 2>/dev/null; then
          mv "${tmp}" "${dest}"
        else
          rm -rf "${tmp}"
          echo "Warning: ${name} download failed." >&2
          plugin_ok=false
        fi
      fi
    done
    ${plugin_ok} && echo "plugins:       installed" || echo "Warning: Plugin pre-install incomplete — plugins will install on first claude launch." >&2

    echo "Done. Run './bin/agent-sandbox verify' to confirm."
    ;;

  verify)
    ok=true

    test -d "${REPO_DIR}/.claude" \
      && echo "claude dir:   OK" \
      || { echo "claude dir:   FAIL (git checkout missing .claude/)"; ok=false; }

    test -f "${REPO_DIR}/.claude/settings.json" \
      && echo "settings:     OK" \
      || { echo "settings:     FAIL (missing .claude/settings.json — git checkout?)"; ok=false; }

    # Warn but don't fail — plugins auto-install on first claude launch if absent
    test -d "${REPO_DIR}/.claude/plugins/cache/caveman" \
      && echo "plugins:      OK" \
      || echo "plugins:      WARN (not pre-installed — run setup after build)"

    test -w "${REPO_DIR}/.claude.json" \
      && echo "session:      OK" \
      || { echo "session:      FAIL (run setup)"; ok=false; }

    test -r "${HOME}/.gitconfig" \
      && echo "gitconfig:    OK" \
      || { echo "gitconfig:    FAIL (create ~/.gitconfig)"; ok=false; }

    ENV_FILE="${REPO_DIR}/.env"
    if [[ -f "$ENV_FILE" ]]; then
      # shellcheck source=/dev/null
      set -a; source "$ENV_FILE"; set +a
    fi
    PROJECTS_DIR="${PROJECTS_DIR:-${HOME}/Repositories}"

    test -w "${PROJECTS_DIR}" \
      && echo "repos write:  OK (${PROJECTS_DIR})" \
      || { echo "repos write:  FAIL (${PROJECTS_DIR}) — run setup"; ok=false; }

    test -w "${HOME}/.config/gh" \
      && echo "gh write:     OK" \
      || echo "gh write:     WARN (run 'gh auth login' on host or inside container)"

    ${ok} && exit 0 || exit 1
    ;;

  build)
    exec docker compose -f "${COMPOSE_FILE}" build agent
    ;;

  down)
    # Stop the shared playwright-mcp sidecar and any agent containers under the
    # wrapper's pinned project.
    exec docker compose -f "${COMPOSE_FILE}" down
    ;;

  *)
    # Preflight: ensure container-local claude state exists as the right kind
    # of inode before docker bind-mounts them (missing paths get auto-created
    # as directories, which breaks the file mount).
    if [[ ! -d "${REPO_DIR}/.claude" ]] || [[ ! -f "${REPO_DIR}/.claude.json" ]]; then
      echo "Error: container claude state not initialised. Run './bin/agent-sandbox setup'." >&2
      exit 1
    fi

    if ! test -S "${SSH_AUTH_SOCK:-}"; then
      echo "Error: SSH_AUTH_SOCK not set or socket missing. Start ssh-agent and add your key." >&2
      exit 1
    fi

    if [[ ! -d "${HOME}/.config/gh" ]]; then
      echo "Note: ${HOME}/.config/gh missing — creating empty dir. Run 'gh auth login' on host (keyring) or inside the container (plaintext)." >&2
      mkdir -p "${HOME}/.config/gh"
    fi

    # If ass set AGENT_WORKDIR, pass it as the container working directory.
    WORKDIR_FLAG=()
    if [[ -n "${AGENT_WORKDIR:-}" ]]; then
      WORKDIR_FLAG=(-w "${AGENT_WORKDIR}")
    fi

    resolve_gh_token
    GH_TOKEN_FLAG=()
    [[ -n "${GH_TOKEN:-}" ]] && GH_TOKEN_FLAG=(-e "GH_TOKEN=${GH_TOKEN}")

    # Ensure the shared playwright-mcp sidecar is up under the wrapper's pinned
    # project (agent-sandbox-${HOST_USER}) so it's reused across worktrees rather
    # than forked per directory. depends_on covers run implicitly; doing it
    # explicitly keeps the lifecycle clear and the single-sidecar invariant.
    docker compose -f "${COMPOSE_FILE}" up -d playwright-mcp

    # bashrc function injects --mcp-config for interactive shell sessions, but
    # is not in scope when claude is passed as a subcommand (non-interactive).
    # Inject the flag explicitly for that path.
    if [[ "${1:-}" == "claude" ]]; then
      shift
      exec docker compose -f "${COMPOSE_FILE}" run --rm "${GH_TOKEN_FLAG[@]}" "${WORKDIR_FLAG[@]}" agent \
        claude --mcp-config "/home/${HOST_USER}/.claude/mcp-config.json" "$@"
    else
      exec docker compose -f "${COMPOSE_FILE}" run --rm "${GH_TOKEN_FLAG[@]}" "${WORKDIR_FLAG[@]}" agent "$@"
    fi
    ;;

esac
