#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
REPO_DIR="$(readlink -f "${SCRIPT_DIR}/..")"

INSTALL_DIR="${HOME}/.local/bin"
INSTALL_PATH="${INSTALL_DIR}/ass"

mkdir -p "${INSTALL_DIR}"

cat > "${INSTALL_PATH}" <<SCRIPT
#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${REPO_DIR}"

ENV_FILE="\${REPO_DIR}/.env"
if [[ -f "\$ENV_FILE" ]]; then
  set -a; source "\$ENV_FILE"; set +a
fi

PROJECTS_DIR="\${PROJECTS_DIR:-\${HOME}/Repositories}"
PROJECTS_BASENAME="\${PROJECTS_BASENAME:-Repositories}"
HOST_PWD="\$(pwd)"

if [[ "\$HOST_PWD" != "\${PROJECTS_DIR}"* ]]; then
  echo "ass: '\$HOST_PWD' is not under your configured projects directory." >&2
  echo "ass: configured: \$PROJECTS_DIR" >&2
  echo "ass: Change to a directory within \\\$PROJECTS_DIR, or re-run './bin/agent-sandbox setup'." >&2
  exit 1
fi

RELATIVE="\${HOST_PWD#\${PROJECTS_DIR}}"
export AGENT_WORKDIR="/home/agent/\${PROJECTS_BASENAME}\${RELATIVE}"

exec "\${REPO_DIR}/bin/agent-sandbox" "\$@"
SCRIPT

chmod +x "${INSTALL_PATH}"
echo "Installed: ${INSTALL_PATH}"
echo "Make sure ${INSTALL_DIR} is in your PATH."
